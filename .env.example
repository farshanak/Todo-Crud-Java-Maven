# ============================================================================
# Todo CRUD Application - Environment Variables
# ============================================================================
# Run: cp .env.example .env
# NEVER commit .env to version control!

# ============================================================================
# REQUIRED - App will not start without these
# ============================================================================

# Database (H2 in-memory for dev, switch to PostgreSQL/MySQL for production)
SPRING_DATASOURCE_URL=jdbc:h2:mem:tododb
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# ============================================================================
# OPTIONAL - Defaults shown
# ============================================================================

# Server
SERVER_PORT=8080

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# H2 Console (disable in production)
SPRING_H2_CONSOLE_ENABLED=true

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE_TODO=DEBUG
